generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(HIRING_MANAGER)
  createdAt    DateTime @default(now())

  jobs      Job[]
  auditLogs AuditLog[]
}

enum Role {
  HIRING_MANAGER
  HR_ADMIN
  CANDIDATE
  RECRUITER
  ADMIN
}

model Job {
  id          String    @id @default(uuid())
  title       String
  description Json
  status      JobStatus @default(DRAFT)
  createdBy   String
  createdAt   DateTime  @default(now())

  user         User          @relation(fields: [createdBy], references: [id])
  applications Application[]
  biasReports  BiasReport[]
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

model Application {
  id          String    @id @default(uuid())
  jobId       String
  candidateId String
  resumeUrl   String
  status      AppStatus @default(APPLIED)
  appliedAt   DateTime  @default(now())

  job         Job             @relation(fields: [jobId], references: [id])
  resumeScore ResumeScore?
  interview   VideoInterview?
}

enum AppStatus {
  APPLIED
  SCREENED
  SHORTLISTED
  INTERVIEWED
  OFFERED
  REJECTED
}

model ResumeScore {
  id              String   @id @default(uuid())
  applicationId   String   @unique
  overallScore    Float
  skillsScore     Float
  experienceScore Float
  educationScore  Float
  explanation     String
  createdAt       DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
}

model VideoInterview {
  id            String          @id @default(uuid())
  applicationId String          @unique
  questions     Json
  recordingUrl  String?
  transcript    String?
  status        InterviewStatus @default(PENDING)
  createdAt     DateTime        @default(now())

  inviteToken    String?   @unique
  expiresAt      DateTime?
  candidateName  String?
  candidateEmail String?
  invitedAt      DateTime?
  completedAt    DateTime?

  application Application @relation(fields: [applicationId], references: [id])
  videoScore  VideoScore?
}
enum InterviewStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EVALUATED
}

model VideoScore {
  id                 String   @id @default(uuid())
  videoInterviewId   String   @unique
  relevanceScore     Float
  communicationScore Float
  behavioralScore    Float
  perQuestionScores  Json
  createdAt          DateTime @default(now())

  videoInterview VideoInterview @relation(fields: [videoInterviewId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  inputData  Json
  outputData Json
  reasoning  String
  actorId    String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])
}

model BiasReport {
  id              String   @id @default(uuid())
  jobId           String
  stage           String
  demographicData Json
  anomalyFlags    Json
  generatedAt     DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])
}